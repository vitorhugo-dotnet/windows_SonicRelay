<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="SonicRelay Windows Publisher"
    Manufacturer="SonicRelay"
    Version="$(ProductVersion)"
    UpgradeCode="{8B20DA7D-91F9-4F9A-AF4A-8D8BB2AF71C0}"
    Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SonicRelay Windows Publisher is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="SonicRelayRootFolder" Name="SonicRelay">
        <Directory Id="INSTALLFOLDER" Name="WindowsPublisher" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SonicRelay" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="SonicRelay Windows Publisher" Level="1">
      <ComponentGroupRef Id="PublishedAppComponents" />
      <ComponentRef Id="ApplicationShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="PublishedAppComponents" Directory="INSTALLFOLDER">
      <Files Include="$(PublishDir)\**" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="ApplicationShortcutComponent" Directory="ApplicationProgramsFolder" Guid="{5AF14B84-8C16-4A7F-BF4B-8296C524269F}">
      <Shortcut
        Id="ApplicationStartMenuShortcut"
        Name="SonicRelay Windows Publisher"
        Description="Launch SonicRelay Windows Publisher"
        Target="[INSTALLFOLDER]SonicRelay.Windows.Desktop.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\SonicRelay\WindowsPublisher"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>

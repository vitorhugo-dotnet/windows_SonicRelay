<Page
    x:Class="SonicRelay.Windows.App.Pages.AudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
    <StackPanel Padding="24" Spacing="12" MaxWidth="720" HorizontalAlignment="Left">
        <TextBlock FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold" Text="System audio" />
        <TextBlock Text="Capture the default Windows output device through WASAPI loopback." TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="StartButton" Content="Start" Click="Start_Click" />
            <Button x:Name="PauseButton" Content="Pause" Click="Pause_Click" IsEnabled="False" />
            <Button x:Name="StopButton" Content="Stop" Click="Stop_Click" IsEnabled="False" />
        </StackPanel>
        <Grid ColumnSpacing="16" RowSpacing="8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="State"/><TextBlock x:Name="StateText" Grid.Column="1" Text="Stopped"/>
            <TextBlock Grid.Row="1" Text="Device"/><TextBlock x:Name="DeviceText" Grid.Row="1" Grid.Column="1" Text="—" TextWrapping="Wrap"/>
            <TextBlock Grid.Row="2" Text="Format"/><TextBlock x:Name="FormatText" Grid.Row="2" Grid.Column="1" Text="—"/>
            <TextBlock Grid.Row="3" Text="Activity"/><ProgressBar x:Name="LevelMeter" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Row="4" Text="Captured"/><TextBlock x:Name="CapturedText" Grid.Row="4" Grid.Column="1" Text="0 frames / 0 bytes"/>
            <TextBlock Grid.Row="5" Text="Last error"/><TextBlock x:Name="ErrorText" Grid.Row="5" Grid.Column="1" Text="—" TextWrapping="Wrap"/>
        </Grid>

        <Border BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <TextBlock FontWeight="SemiBold" Text="Audio source" />
                <TextBlock Text="Choose which Windows output device is captured and published. The change applies the next time capture starts."
                           TextWrapping="Wrap" Opacity="0.8" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="OutputCombo" Header="Output device" MinWidth="320"
                              SelectionChanged="Output_SelectionChanged" />
                    <Button x:Name="RefreshDevicesButton" Content="Refresh" Click="RefreshDevices_Click"
                            VerticalAlignment="Bottom" />
                </StackPanel>
                <TextBlock x:Name="OutputFallbackText" Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           TextWrapping="Wrap" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Border BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <TextBlock FontWeight="SemiBold" Text="Stream quality (Opus)" />
                <TextBlock Text="Choose how audio is encoded before it is sent over WebRTC. Lower profiles reduce bandwidth; the change applies the next time capture starts."
                           TextWrapping="Wrap" Opacity="0.8" />
                <ComboBox x:Name="QualityCombo" Header="Profile" MinWidth="260"
                          SelectionChanged="Quality_SelectionChanged" />
                <StackPanel x:Name="CustomPanel" Spacing="8" Visibility="Collapsed">
                    <ComboBox x:Name="CustomChannels" Header="Channels" MinWidth="160">
                        <ComboBoxItem Content="Mono (1)" Tag="1" />
                        <ComboBoxItem Content="Stereo (2)" Tag="2" />
                    </ComboBox>
                    <NumberBox x:Name="CustomBitrate" Header="Bitrate (kbps)" Minimum="16" Maximum="192"
                               SmallChange="8" LargeChange="16" SpinButtonPlacementMode="Inline" MinWidth="200" />
                    <ComboBox x:Name="CustomFrame" Header="Frame duration (ms)" MinWidth="160">
                        <ComboBoxItem Content="10 ms" Tag="10" />
                        <ComboBoxItem Content="20 ms" Tag="20" />
                        <ComboBoxItem Content="40 ms" Tag="40" />
                    </ComboBox>
                    <Button x:Name="CustomApplyButton" Content="Apply custom profile" Click="CustomApply_Click" />
                    <TextBlock x:Name="CustomErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
                <TextBlock x:Name="QualityHintText" Opacity="0.7"
                           Text="The selected profile applies when capture starts." TextWrapping="Wrap" />
                <TextBlock FontWeight="SemiBold" Text="Effective settings" Margin="0,4,0,0" />
                <Grid ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Codec"/><TextBlock x:Name="CodecText" Grid.Column="1" Text="Opus"/>
                    <TextBlock Grid.Row="1" Text="Bitrate"/><TextBlock x:Name="BitrateText" Grid.Row="1" Grid.Column="1" Text="—"/>
                    <TextBlock Grid.Row="2" Text="Channels"/><TextBlock x:Name="ChannelsText" Grid.Row="2" Grid.Column="1" Text="—"/>
                    <TextBlock Grid.Row="3" Text="Frame duration"/><TextBlock x:Name="FrameText" Grid.Row="3" Grid.Column="1" Text="—"/>
                    <TextBlock Grid.Row="4" Text="Sample rate"/><TextBlock x:Name="SampleRateText" Grid.Row="4" Grid.Column="1" Text="—"/>
                    <TextBlock Grid.Row="5" Text="Est. traffic"/><TextBlock x:Name="EstimateText" Grid.Row="5" Grid.Column="1" Text="—" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Page>

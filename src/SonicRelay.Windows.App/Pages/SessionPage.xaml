<Page x:Class="SonicRelay.Windows.App.Pages.SessionPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Padding="24" Spacing="14" MaxWidth="640" HorizontalAlignment="Left">
    <TextBlock FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold" Text="Session"/>
    <StackPanel Orientation="Horizontal" Spacing="8"><Button x:Name="CreateButton" Content="Create session" Click="Create_Click"/><Button x:Name="RefreshButton" Content="Refresh viewers" Click="Refresh_Click"/><Button x:Name="EndButton" Content="End session" Click="End_Click"/></StackPanel>
    <Border Style="{StaticResource DashboardCardStyle}" Padding="20"><StackPanel Spacing="6"><TextBlock Text="Session code"/><TextBlock x:Name="CodeText" FontSize="32" FontWeight="Bold" Text="—"/></StackPanel></Border>
    <Grid ColumnSpacing="12" RowSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Signaling"/><TextBlock x:Name="SignalingText" Grid.Column="1" Text="Disconnected"/><TextBlock Grid.Row="1" Text="Viewers"/><TextBlock x:Name="ViewerText" Grid.Row="1" Grid.Column="1" Text="0"/></Grid>
    <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False" IsClosable="False"/>
  </StackPanel>
</Page>

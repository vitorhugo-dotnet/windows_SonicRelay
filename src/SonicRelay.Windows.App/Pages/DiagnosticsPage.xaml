<Page
    x:Class="SonicRelay.Windows.App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer>
    <StackPanel Padding="24" Spacing="12" MaxWidth="900" HorizontalAlignment="Left">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold" Text="Diagnostics" />
        <Button Grid.Column="1" Click="ExportReport" Content="Export safe report" />
      </Grid>
      <TextBlock x:Name="ExportStatus" Style="{StaticResource MockStatusTextStyle}" TextWrapping="Wrap" />
      <Grid ColumnDefinitions="180,*" RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="App version"/><TextBlock x:Name="AppVersionText" Grid.Row="0" Grid.Column="1"/>
        <TextBlock Grid.Row="1" Text="Runtime"/><TextBlock x:Name="RuntimeVersionText" Grid.Row="1" Grid.Column="1"/>
        <TextBlock Grid.Row="2" Text="OS"/><TextBlock x:Name="OsVersionText" Grid.Row="2" Grid.Column="1"/>
        <TextBlock Grid.Row="3" Text="Backend"/><TextBlock x:Name="BackendText" Grid.Row="3" Grid.Column="1"/>
        <TextBlock Grid.Row="4" Text="Authentication"/><TextBlock x:Name="AuthText" Grid.Row="4" Grid.Column="1"/>
        <TextBlock Grid.Row="5" Text="Device ID"/><TextBlock x:Name="DeviceText" Grid.Row="5" Grid.Column="1"/>
        <TextBlock Grid.Row="6" Text="Session ID"/><TextBlock x:Name="SessionText" Grid.Row="6" Grid.Column="1"/>
        <TextBlock Grid.Row="7" Text="Signaling"/><TextBlock x:Name="SignalingText" Grid.Row="7" Grid.Column="1"/>
        <TextBlock Grid.Row="8" Text="Viewers / WebRTC peers"/><TextBlock x:Name="ViewerText" Grid.Row="8" Grid.Column="1"/>
        <TextBlock Grid.Row="9" Text="Audio capture"/><TextBlock x:Name="AudioStateText" Grid.Row="9" Grid.Column="1"/>
        <TextBlock Grid.Row="10" Text="Audio output"/><TextBlock x:Name="AudioDeviceText" Grid.Row="10" Grid.Column="1" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="11" Text="Audio level"/><ProgressBar x:Name="AudioLevel" Grid.Row="11" Grid.Column="1" Minimum="0" Maximum="100"/>
      </Grid>
      <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Last non-sensitive errors"/>
      <ListView x:Name="ErrorList" MaxHeight="180"/>
      <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Recent activity"/>
      <ListView x:Name="LogList" MaxHeight="320"/>
    </StackPanel>
  </ScrollViewer>
</Page>

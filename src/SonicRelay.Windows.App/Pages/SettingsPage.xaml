<Page x:Class="SonicRelay.Windows.App.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Padding="24" Spacing="12" MaxWidth="640" HorizontalAlignment="Left">
    <TextBlock FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold" Text="Settings"/>
    <TextBlock Text="Publisher preferences. Theme follows Windows."/>
    <TextBlock Text="Connection" FontWeight="SemiBold" Margin="0,12,0,0"/>
    <ToggleSwitch x:Name="RelayToggle" Header="Force relay (TURN only)" OffContent="Off" OnContent="On" Toggled="RelayToggle_Toggled"/>
    <TextBlock TextWrapping="Wrap" Opacity="0.7"
               Text="Route audio through the relay server instead of connecting directly. Turn on for restrictive networks; leave off to prefer a direct connection. Applies to the next connection."/>

    <TextBlock Text="Background &amp; tray" FontWeight="SemiBold" Margin="0,20,0,0"/>
    <ToggleSwitch x:Name="KeepInTrayToggle" Header="Keep SonicRelay running in tray when the window is closed" OffContent="Off" OnContent="On" Toggled="TrayToggle_Toggled"/>
    <TextBlock TextWrapping="Wrap" Opacity="0.7"
               Text="Closing or minimizing the window hides it to the notification area and keeps publishing. Use the tray icon or 'Quit SonicRelay' to stop."/>
    <ToggleSwitch x:Name="StartMinimizedToggle" Header="Start minimized to tray" OffContent="Off" OnContent="On" Toggled="TrayToggle_Toggled"/>
    <ToggleSwitch x:Name="NotificationsToggle" Header="Show background/tray notifications" OffContent="Off" OnContent="On" Toggled="TrayToggle_Toggled"/>
  </StackPanel>
</Page>

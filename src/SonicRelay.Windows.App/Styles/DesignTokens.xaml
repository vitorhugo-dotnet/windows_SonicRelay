<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F3F3" />
      <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CCFFFFFF" />
      <SolidColorBrush x:Key="StatusNeutralBrush" Color="#5C5C5C" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#202020" />
      <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CC2B2B2B" />
      <SolidColorBrush x:Key="StatusNeutralBrush" Color="#BEBEBE" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
  <x:Double x:Key="SpacingSmall">8</x:Double>
  <x:Double x:Key="SpacingMedium">16</x:Double>
  <x:Double x:Key="SpacingLarge">24</x:Double>
  <x:Double x:Key="TitleFontSize">28</x:Double>
  <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
  <Style x:Key="DashboardCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
    <Setter Property="Padding" Value="16" />
  </Style>
  <Style x:Key="MockStatusTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{ThemeResource StatusNeutralBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
</ResourceDictionary>
